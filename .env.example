# AeroCheck Environment Variables
# Copy this file to .env and fill in your API keys

# ===========================================
# WEATHER APIs
# ===========================================

# OpenWeatherMap (https://openweathermap.org/api)
# Free tier: 60 calls/minute
VITE_OPENWEATHER_API_KEY=your_openweathermap_api_key

# WeatherAPI (https://www.weatherapi.com)
# Free tier: 1M calls/month
VITE_WEATHERAPI_KEY=your_weatherapi_key

# Tomorrow.io (https://www.tomorrow.io)
# Free tier: 500 calls/day
VITE_TOMORROW_API_KEY=your_tomorrow_api_key

# ===========================================
# AVIATION APIs
# ===========================================

# Aviationstack (https://aviationstack.com)
# Free tier: 100 calls/month
VITE_AVIATIONSTACK_KEY=your_aviationstack_key

# AeroDataBox via RapidAPI (https://rapidapi.com)
# Sign up at RapidAPI and search for AeroDataBox
VITE_AERODATABOX_KEY=your_rapidapi_key

# Aviation Edge (https://aviation-edge.com)
# Free tier: 1000 calls/month
VITE_AVIATION_EDGE_KEY=your_aviation_edge_key

# ===========================================
# GEOCODING APIs
# ===========================================

# Geocodeify (https://geocodeify.com)
# Free tier: 10,000 calls/month
VITE_GEOCODEIFY_KEY=your_geocodeify_key

# Note: Nominatim (OpenStreetMap) is used without API key
# Rate limited to 1 request/second

# ===========================================
# DEVELOPMENT SETTINGS
# ===========================================

# Set to 'development' or 'production'
VITE_APP_ENV=development
